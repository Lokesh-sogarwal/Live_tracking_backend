# Copy this file to .env and fill in the real values before deploying.

# Flask settings
FLASK_ENV=production
DEBUG=False
PORT=5000

# Secret keys
SECRET_KEY=replace-with-a-secure-secret
JWT_SECRET_KEY=replace-with-jwt-secret

# Database: Provide your Aiven / managed MySQL URL here.
# Example: mysql+pymysql://username:password@host:port/dbname
LOCAL_DATABASE_URL=

# Optional overrides
USE_LOCAL_MYSQL=1

# Uploads
UPLOAD_FOLDER=uploads
