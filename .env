# ===== FLASK SETTINGS =====
FLASK_APP=app.py
FLASK_ENV=production
DEBUG=False
PORT=5000
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax
MAX_CONTENT_LENGTH=16777216  # 16MB in bytes

# ===== SECURITY =====
SECRET_KEY=HackathonDeploymentSecretKeyChangeThis
JWT_SECRET_KEY=SuperSecureJWTSecretChangeThis

# ===== DATABASE =====
# For deployment change localhost → cloud DB host
DATABASE_URL=mysql+pymysql://root:Lok%402004@localhost/hackathon

# ===== CORS =====
CORS_ALLOWED_ORIGINS=*
CORS_SUPPORTS_CREDENTIALS=True

# ===== UPLOADS =====
UPLOAD_FOLDER=uploads
